/*
========================================================================================
    Singularity config file
========================================================================================
    Configuration for running with Singularity containers
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Singularity'
    config_profile_description = 'Configuration for running with Singularity containers'
    
    // Singularity-specific parameters
    lemontree_jar             = '/opt/lemontree/lemontree_v3.1.1.jar'
    pkn_network               = "${projectDir}/PKN/Lemonite_PKN.tsv"
}

process {
    executor = 'local'
    
    // Use the Singularity image built from Singularity.def
    container = "${projectDir}/lemontree-pipeline.sif"
    
    // Optimized resource allocation for 8-core system with 32GB RAM
    cpus   = { check_max( 2     * task.attempt, 'cpus'    ) }
    memory = { check_max( 4.GB * task.attempt, 'memory'  ) }
    time   = { check_max( 4.h   * task.attempt, 'time'    ) }

    // Process-specific configurations optimized for parallelization
    withName:PREPROCESSING_TFA {
        cpus   = { check_max( 6     * task.attempt, 'cpus'    ) }
        memory = { check_max( 24.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 3.h   * task.attempt, 'time'    ) }
    }
    
    // Optimize clustering for parallel execution (50 rounds)
    withName:CLUSTERING {
        cpus   = { check_max( 1     * task.attempt, 'cpus'    ) }
        memory = { check_max( 2.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 6.h   * task.attempt, 'time'    ) }
    }
    
    withName:NETWORK_GENERATION {
        cpus   = { check_max( 4     * task.attempt, 'cpus'    ) }
        memory = { check_max( 12.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 2.h   * task.attempt, 'time'    ) }
    }
    
    withName:ENRICHMENT_ANALYSIS {
        cpus   = { check_max( 7     * task.attempt, 'cpus'    ) }
        memory = { check_max( 28.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 4.h   * task.attempt, 'time'    ) }
    }
    
    withName:PKN_EVALUATION {
        cpus   = { check_max( 4     * task.attempt, 'cpus'    ) }
        memory = { check_max( 12.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 2.h   * task.attempt, 'time'    ) }
    }
    
    withName:MODULE_VIEWER_HEATMAPS {
        cpus   = { check_max( 3     * task.attempt, 'cpus'    ) }
        memory = { check_max( 8.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 1.h   * task.attempt, 'time'    ) }
    }
    
    withName:MODULE_OVERVIEW_INTERACTIVE {
        cpus   = { check_max( 4     * task.attempt, 'cpus'    ) }
        memory = { check_max( 16.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 2.h   * task.attempt, 'time'    ) }
    }
}

// Executor settings for maximum parallelization
executor {
    name = 'local'
    cpus = 8
    memory = '32 GB'
    queueSize = 50  // Allow up to 50 concurrent tasks
}

singularity {
    enabled = true
    autoMounts = true
    // Bind mount working directories and set working directory inside container
    // This fixes the "Error changing the container working directory" issue
    // DEVELOPMENT MODE: Bind mount scripts and PKN directories to use latest versions without rebuilding container
    // This allows rapid iteration on scripts without needing to rebuild the Singularity image
    // HPC FIX: Bind the entire scratch directory to ensure symlinks between work directories are accessible
    // The work directory contains symlinks pointing to other work subdirectories, which need to be accessible
    runOptions = { 
        def baseBinds = "--cleanenv --pwd \$PWD --bind \$PWD:\$PWD --bind ${projectDir}/scripts:${projectDir}/scripts --bind ${projectDir}/PKN:${projectDir}/PKN"
        // Add work directory bind if it exists and is different from PWD
        def workDirBind = ""
        if (params.input_dir) {
            workDirBind = " --bind ${params.input_dir}:${params.input_dir}"
        }
        // Add scratch directory bind for HPC systems (like VSC/kyukon)
        def scratchBind = ""
        if (new File('/kyukon').exists()) {
            scratchBind = " --bind /kyukon:/kyukon"
        }
        return baseBinds + workDirBind + scratchBind
    }()
}

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
