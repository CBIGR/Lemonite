/*
========================================================================================
    HPC Config File
========================================================================================
    Configuration optimized for High Performance Computing (HPC) environments
    with SLURM, PBS, or other schedulers.
    
    Usage:
        nextflow run main.nf -profile hpc,singularity [other options]
    
    Note: You may need to adjust the queue/partition names and resource limits
    based on your specific HPC system.
----------------------------------------------------------------------------------------
*/

process {
    // Default HPC resources - more generous than local
    cpus   = { check_max( 8    * task.attempt, 'cpus'   ) }
    memory = { check_max( 32.GB * task.attempt, 'memory' ) }
    time   = { check_max( 24.h  * task.attempt, 'time'   ) }

    // Error strategy for HPC - more aggressive retries
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 3
    maxErrors = '-1'

    // Process-specific configurations optimized for HPC
    withName:PREPROCESSING_TFA {
        cpus   = { check_max( 12    * task.attempt, 'cpus'    ) }
        memory = { check_max( 64.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 6.h   * task.attempt, 'time'    ) }
    }
    
    withName:CLUSTERING {
        cpus   = { check_max( 2     * task.attempt, 'cpus'    ) }
        memory = { check_max( 8.GB  * task.attempt, 'memory'  ) }
        time   = { check_max( 12.h  * task.attempt, 'time'    ) }
    }
    
    withName:POST_CLUSTERING {
        cpus   = { check_max( 8     * task.attempt, 'cpus'    ) }
        memory = { check_max( 32.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 12.h  * task.attempt, 'time'    ) }
    }
    
    withName:NETWORK_GENERATION {
        cpus   = { check_max( 8     * task.attempt, 'cpus'    ) }
        memory = { check_max( 32.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 6.h   * task.attempt, 'time'    ) }
    }
    
    withName:ENRICHMENT_ANALYSIS {
        cpus   = { check_max( 16    * task.attempt, 'cpus'    ) }
        memory = { check_max( 64.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 12.h  * task.attempt, 'time'    ) }
    }
    
    withName:PKN_EVALUATION {
        cpus   = { check_max( 8     * task.attempt, 'cpus'    ) }
        memory = { check_max( 32.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 4.h   * task.attempt, 'time'    ) }
    }
    
    withName:MODULE_VIEWER_HEATMAPS {
        cpus   = { check_max( 8     * task.attempt, 'cpus'    ) }
        memory = { check_max( 32.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 6.h   * task.attempt, 'time'    ) }
    }
    
    withName:MODULE_OVERVIEW_INTERACTIVE {
        cpus   = { check_max( 16    * task.attempt, 'cpus'    ) }
        memory = { check_max( 64.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 72.h  * task.attempt, 'time'    ) }  // Extended for megago clustering
    }
    
    withName:SUBNETWORK_GRAPHS {
        cpus   = { check_max( 8     * task.attempt, 'cpus'    ) }
        memory = { check_max( 32.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 8.h   * task.attempt, 'time'    ) }
    }
}

// HPC executor configuration (uncomment and adjust for your system)
// executor {
//     name = 'slurm'  // or 'pbs', 'lsf', 'sge', etc.
//     queueSize = 50
//     submitRateLimit = '10 sec'
// }

// SLURM-specific options (uncomment if using SLURM)
// process {
//     executor = 'slurm'
//     queue = 'normal'  // Change to your partition name
//     clusterOptions = '--account=YOUR_ACCOUNT'  // Add your account if required
// }

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
