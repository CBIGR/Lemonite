/*
========================================================================================
    Base Nextflow config file
========================================================================================
    Default resource allocations and publishDir configuration for all processes.
    Profile-specific configs (singularity.config, hpc.config) can override these.
----------------------------------------------------------------------------------------
*/

// Centralized output directory - computed once, used by all processes
def baseOutputDir = { -> "${(params.output_dir ?: (params.input_dir ? params.input_dir + '/results' : './results'))}/${(params.computed_run_id ?: (params.run_id ?: 'run_auto'))}" }

process {

    cpus   = { check_max( 2    * task.attempt, 'cpus'   ) }
    memory = { check_max( 4.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h  * task.attempt, 'time'   ) }

    // Default error strategy: retry on OOM/signal kills
    errorStrategy = { task.exitStatus in [137,140,143] ? 'retry' : 'terminate' }
    maxRetries = 2

    // Centralized publishDir per process
    withName:LOG_PARAMETERS {
        publishDir = [ path: { baseOutputDir() }, mode: 'copy' ]
    }
    withName:PREPROCESSING_TFA {
        publishDir = [ path: { baseOutputDir() }, mode: 'copy' ]
        cpus   = { check_max( 6     * task.attempt, 'cpus'    ) }
        memory = { check_max( 24.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 3.h   * task.attempt, 'time'    ) }
    }
    withName:CLUSTERING {
        publishDir = [ path: { "${baseOutputDir()}/LemonTree/Lemon_out" }, mode: 'copy' ]
        cpus   = { check_max( 1     * task.attempt, 'cpus'    ) }
        memory = { check_max( 2.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 6.h   * task.attempt, 'time'    ) }
    }
    withName:POST_CLUSTERING {
        publishDir = [ path: { "${baseOutputDir()}/LemonTree" }, mode: 'copy', pattern: "Lemon_out/*" ]
    }
    withName:NETWORK_GENERATION {
        publishDir = [ path: { "${baseOutputDir()}/LemonTree" }, mode: 'copy' ]
        cpus   = { check_max( 4     * task.attempt, 'cpus'    ) }
        memory = { check_max( 12.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 2.h   * task.attempt, 'time'    ) }
    }
    withName:SUBNETWORK_GRAPHS {
        publishDir = [ path: { "${baseOutputDir()}/LemonTree" }, mode: 'copy' ]
    }
    withName:PKN_EVALUATION {
        publishDir = [ path: { "${baseOutputDir()}/LemonTree" }, mode: 'copy' ]
        cpus   = { check_max( 4     * task.attempt, 'cpus'    ) }
        memory = { check_max( 12.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 2.h   * task.attempt, 'time'    ) }
    }
    withName:MODULE_VIEWER_HEATMAPS {
        publishDir = [ path: { "${baseOutputDir()}/LemonTree/module_heatmaps" }, mode: 'copy' ]
        cpus   = { check_max( 3     * task.attempt, 'cpus'    ) }
        memory = { check_max( 8.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 1.h   * task.attempt, 'time'    ) }
    }
    withName:ENRICHMENT_ANALYSIS {
        publishDir = [ path: { "${baseOutputDir()}/LemonTree" }, mode: 'copy' ]
        cpus   = { check_max( 7     * task.attempt, 'cpus'    ) }
        memory = { check_max( 28.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 4.h   * task.attempt, 'time'    ) }
    }
    withName:MODULE_OVERVIEW_INTERACTIVE {
        publishDir = [ path: { "${baseOutputDir()}/LemonTree" }, mode: 'copy' ]
        cpus   = { check_max( 4     * task.attempt, 'cpus'    ) }
        memory = { check_max( 16.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 48.h  * task.attempt, 'time'    ) }
    }
    withName:SUMMARY_REPORT {
        publishDir = [ path: { baseOutputDir() }, mode: 'copy' ]
        memory = { check_max( 8.GB  * task.attempt, 'memory'  ) }
        cpus   = 2
        time   = { check_max( 1.h   * task.attempt, 'time'    ) }
    }
}

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
