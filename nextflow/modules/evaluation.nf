process PKN_EVALUATION {
    tag "PKN evaluation"
    publishDir "${(params.output_dir ?: (params.input_dir ? params.input_dir + '/results' : './results'))}/${(params.computed_run_id ?: (params.run_id ?: 'run_auto'))}/LemonTree", mode: 'copy'

    input:
    path networks
    path viewer_files
    path data_dir
    val run_id
    val regulator_types

    output:
    path "PKN_Evaluation/*", emit: pkn_results, optional: true
    path "ModuleViewer_files/*", emit: viewer_files
    path "ModuleViewer_files/sample_mapping.mvf", emit: sample_mapping
    path "Networks/subnetworks/*.png", emit: subnetwork_plots, optional: true

    script:
    def top_n_percent_regulators = params.top_n_percent_regulators ?: 10.0

    """
    # Ensure ModuleViewer_files exists and copy existing viewer files into it
    mkdir -p ModuleViewer_files
    # Copy all existing viewer files (sample_mapping.mvf etc.) into the canonical results location
    for f in ${viewer_files}; do
        if [ -d "\$f" ]; then
            cp -L -r "\$f"/* ModuleViewer_files/ || true
        else
            cp -L -r "\$f" ModuleViewer_files/ || true
        fi
    done
    
    # Create Networks directory and copy network files to it
    mkdir -p Networks
    # Copy all network files to Networks directory
    for f in ${networks}; do
        if [ -f "\$f" ]; then
            cp -L "\$f" Networks/ || true
        fi
    done
    
    # List all available files for debugging
    echo "=== Available network files ==="
    find Networks/ -name "*.txt" -type f
    echo "================================="
    
    # Create working directory structure
    mkdir -p PKN_Evaluation
    workdir=\$(pwd)

    # Try to locate clusters file for downstream analysis
    cluster_file=\$(find . -name "clusters_list.txt" | head -1)
    if [ -z "\$cluster_file" ]; then
        # fallback to any clusters-like file generated by LemonTree
        cluster_file=\$(find . -name "clusters_*" -type f | head -1)
    fi

    # Find required files - look in Networks directory first
    network_file=\$(find Networks/ -name "LemonNetwork_*.txt" | head -1)
    if [ -z "\$network_file" ]; then
        network_file=\$(find Networks/ -name "Metabolites2targets_*.txt" | head -1)
        echo "Using metabolite targets file: \$network_file"
    else
        echo "Found LemonNetwork file: \$network_file"
    fi
    
    if [ -z "\$network_file" ]; then
        echo "Error: No network file found in Networks directory"
        echo "Available .txt files in Networks/:"
        find Networks/ -name "*.txt" -type f
        echo "Contents of Networks directory:"
        ls -la Networks/
        exit 1
    fi
    
    # Find regulator files dynamically based on regulator_types
    # Parse regulator_types (format: "Prefix:DataFile,Prefix:DataFile")
    IFS=',' read -ra REG_TYPES <<< "${regulator_types}"
    
    # Initialize regulator file variables
    declare -A regulator_files=()
    
    for reg_type in "\${REG_TYPES[@]}"; do
        # Extract prefix and datafile (e.g., "TFs:TF_list.txt" -> prefix="TFs", datafile="TF_list.txt")
        IFS=':' read -r reg_prefix reg_datafile <<< "\$reg_type"
        reg_prefix=\$(echo \$reg_prefix | xargs)        # trim whitespace
        reg_datafile=\$(echo \$reg_datafile | xargs)    # trim whitespace
        
        # Find regulator file for this prefix (use Prefix, not data filename)
        reg_file=\$(find Networks/ -name "\${reg_prefix}.selected_regs_list.txt" | head -1)
        
        # If not found in Networks, try current directory
        if [ -z "\$reg_file" ]; then
            reg_file=\$(find . -name "\${reg_prefix}.selected_regs_list.txt" | head -1)
        fi
        
        if [ -n "\$reg_file" ]; then
            regulator_files[\$reg_prefix]="\$reg_file"
            echo "Found \${reg_prefix} regulator file: \$reg_file"
        else
            echo "Warning: \${reg_prefix} regulator file not found"
        fi
    done
    
    # PKN files (available in the container)
    pkn_file="/opt/PKN/Lemonite_PKN.tsv"
    metabolite_interactions_file="/opt/PKN/HMDB_metabolites_gene_interactions.tsv"
    
    # Look for metabolite mapping file in data directory and current directory
    metabolite_mapping_file=""
    for name in name_map.csv metabolite_mapping.csv compound_mapping.csv; do
        if [ -f "data/\$name" ]; then
            metabolite_mapping_file="data/\$name"
            break
        elif [ -f "\$name" ]; then
            metabolite_mapping_file="\$name"
            break
        fi
    done
    
    if [ -z "\$metabolite_mapping_file" ]; then
        echo "Warning: Metabolite mapping file not found, creating minimal placeholder"
        echo "Query,HMDB" > /tmp/name_map.csv
        echo "dummy,HMDB0000001" >> /tmp/name_map.csv
        metabolite_mapping_file="/tmp/name_map.csv"
    fi
    
    echo "Running PKN evaluation..."
    echo "Network file: \$network_file"
    echo "Regulator types: ${regulator_types}"
    
    # Print found regulator files
    for reg_type in "\${!regulator_files[@]}"; do
        echo "\${reg_type} regulator file: \${regulator_files[\$reg_type]}"
    done
    
    echo "Cluster file: \$cluster_file"
    echo "Metabolite mapping file: \$metabolite_mapping_file"
    echo "Working directory: \$workdir"
    
    # Check if regulator files exist and show their sizes
    for reg_type in "\${!regulator_files[@]}"; do
        reg_file="\${regulator_files[\$reg_type]}"
        if [ -f "\$reg_file" ]; then
            LINECOUNT=\$(wc -l < "\$reg_file")
            echo "\${reg_type} regulator file found (\$LINECOUNT lines)"
            echo "First few lines:"
            head -3 "\$reg_file"
        else
            echo "ERROR: \${reg_type} regulator file not found!"
        fi
    done
    
    # Check host script first (allows updates without rebuilding container)
    if [ -f "${projectDir}/scripts/evaluate_against_PKN.py" ]; then
        SCRIPT_PATH="${projectDir}/scripts/evaluate_against_PKN.py"
    elif [ -f "/app/scripts/evaluate_against_PKN.py" ]; then
        SCRIPT_PATH="/app/scripts/evaluate_against_PKN.py"
    else
        echo "Error: evaluate_against_PKN.py not found"
        exit 1
    fi
    # Build regulator_files argument
    regulator_files_arg=""
    for reg_type in "\${!regulator_files[@]}"; do
        reg_file="\${regulator_files[\$reg_type]}"
        if [ -n "\$regulator_files_arg" ]; then
            regulator_files_arg="\$regulator_files_arg,\$reg_type:\$reg_file"
        else
            regulator_files_arg="\$reg_type:\$reg_file"
        fi
    done
    
    python3 \$SCRIPT_PATH \\
        --workdir "\$workdir" \\
        --network_file "\$network_file" \\
        --pkn_file "\$pkn_file" \\
        --metabolite_interactions_file "\$metabolite_interactions_file" \\
        --metabolite_mapping_file "\$metabolite_mapping_file" \\
        --regulator_files "\$regulator_files_arg" \\
        --cluster_file "\$cluster_file" \\
        --cores ${task.cpus}
    
    # Ensure results ModuleViewer_files exists and copy existing viewer files into it
    mkdir -p results/ModuleViewer_files
    # Copy all existing viewer files (sample_mapping.mvf etc.) into the canonical results location
    for f in ${viewer_files}; do
        if [ -d "\$f" ]; then
            cp -L -r "\$f"/* results/ModuleViewer_files/ || true
        else
            cp -L -r "\$f" results/ModuleViewer_files/ || true
        fi
    done

    # Copy results back to the expected output location for Nextflow
    mkdir -p ModuleViewer_files
    cp -r results/ModuleViewer_files/* ModuleViewer_files/ || true

    # Check for generated MVF and report/copy if found in other locations
    if [ -f "\$workdir/results/ModuleViewer_files/metabolite_LemoniteKG_interactions.mvf" ]; then
        echo "metabolite_LemoniteKG_interactions.mvf generated in results/ModuleViewer_files"
    elif [ -f "ModuleViewer_files/metabolite_LemoniteKG_interactions.mvf" ]; then
        cp ModuleViewer_files/metabolite_LemoniteKG_interactions.mvf results/ModuleViewer_files/
        echo "Copied metabolite_LemoniteKG_interactions.mvf from ModuleViewer_files to results/ModuleViewer_files"
    else
        echo "Warning: metabolite_LemoniteKG_interactions.mvf not found in results/ModuleViewer_files/ or ModuleViewer_files/"
        ls -la ModuleViewer_files/ || echo "ModuleViewer_files directory not found"
    fi
    
    # Check for PPI_interactions.mvf file
    if [ -f "\$workdir/ModuleViewer_files/PPI_interactions.mvf" ]; then
        echo "PPI_interactions.mvf generated successfully"
        cp \$workdir/ModuleViewer_files/PPI_interactions.mvf ModuleViewer_files/ || true
    elif [ -f "ModuleViewer_files/PPI_interactions.mvf" ]; then
        echo "PPI_interactions.mvf found in ModuleViewer_files"
    else
        echo "Warning: PPI_interactions.mvf not found - this may affect module viewer PPI visualization"
        ls -la ModuleViewer_files/ || echo "ModuleViewer_files directory not found"
    fi
    
    echo "PKN evaluation completed"
    """

    stub:
    """
    mkdir -p PKN_Evaluation
    mkdir -p ModuleViewer_files
    touch PKN_Evaluation/evaluation_results.txt
    touch PKN_Evaluation/evaluation_summary.txt
    touch ModuleViewer_files/metabolite_LemoniteKG_interactions.mvf
    touch ModuleViewer_files/PPI_interactions.mvf
    touch ModuleViewer_files/sample_mapping.mvf
    """
}
